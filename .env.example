# copy this to .env and drop your real keys in. .env is gitignored so it never leaves your machine.

# --- model providers ---
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# optional extra providers / tools
GROQ_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
WOLFRAM_ALPHA_APPID=
OPENWEATHER_API_KEY=
NEWSAPI_KEY=

# --- agent behaviour (these all have sane defaults, override if you want) ---
AIAGENT_PROVIDER=openai
AIAGENT_MODEL=gpt-4o
AIAGENT_TEMPERATURE=0.2
AIAGENT_MAX_TOKENS=2048
AIAGENT_VERBOSE=true
AIAGENT_STREAM=true
AIAGENT_MEMORY_ENABLED=true
AIAGENT_RAG_ENABLED=false
AIAGENT_CACHE_ENABLED=true
AIAGENT_LOG_LEVEL=INFO
